# Example only. Add real values in Vercel Settings > Environment Variables.
# Never commit secrets or paste them into browser-accessible website files.

# Shared portal database — Vercel Marketplace / Upstash Redis usually injects these.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alternative variable names supported by the portal backend.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Authentication — use a unique random value at least 32 characters long.
AUTH_SECRET=

# First staff administrator. The account is created when it does not already exist.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Blackstone Founder

# Discord gallery, OAuth member sign-in and member/role synchronisation.
DISCORD_BOT_TOKEN=
DISCORD_GALLERY_CHANNEL_ID=1520414735772811394
DISCORD_GALLERY_LIMIT=24
DISCORD_GUILD_ID=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Optional overrides. Normally the callback URL is detected from the Vercel domain.
DISCORD_REDIRECT_URI=
PUBLIC_SITE_URL=
