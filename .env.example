# Vercel production URL (no trailing slash)
PUBLIC_SITE_URL=https://blackstone-rp-website-9d5j.vercel.app
DISCORD_REDIRECT_URI=https://blackstone-rp-website-9d5j.vercel.app/api/discord-callback

# Portal security and initial founder account
AUTH_SECRET=replace-with-at-least-32-random-characters
ADMIN_EMAIL=replace@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_NAME=Blackstone Founder

# Upstash Redis / Vercel Marketplace integration
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternatively:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Discord application and bot
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_GALLERY_CHANNEL_ID=1520414735772811394
DISCORD_GALLERY_LIMIT=24

# Two-way Discord announcements
DISCORD_ANNOUNCEMENTS_CHANNEL_ID=1520408782520193115
DISCORD_ANNOUNCEMENTS_LIMIT=50
# Optional: set true only when this is a Discord Announcement channel and you want automatic publishing
DISCORD_ANNOUNCEMENTS_CROSSPOST=false
